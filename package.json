{
  "name": "beautify",
  "displayName": "Beautify",
  "description": "Beautify code in place for VS Code",
  "version": "1.5.2",
  "publisher": "Marvello",
  "engines": {
    "vscode": "^1.32.0"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Formatters"
  ],
  "activationEvents": [
    "onCommand:Marvello.beautify",
    "onCommand:Marvello.beautifyFile",
    "onLanguage:javascript",
    "onLanguage:json",
    "onLanguage:jsonc",
    "onLanguage:css",
    "onLanguage:less",
    "onLanguage:scss",
    "onLanguage:html",
    "onLanguage:htm"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#e8e030",
    "theme": "light"
  },
  "license": "MIT",
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "json",
        "aliases": [
          "JSON"
        ],
        "filenames": [
          ".jsbeautifyrc",
          ".jshintrc"
        ]
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": ".jsbeautifyrc",
        "url": "./schema/beautifyrc.json"
      }
    ],
    "commands": [
      {
        "command": "Marvello.beautify",
        "title": "Beautify selection"
      },
      {
        "command": "Marvello.beautifyFile",
        "title": "Beautify file"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Beautify config",
      "properties": {
        "beautify.ignore": {
          "type": [
            "string",
            "array"
          ],
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "List of paths to ignore when using VS Code format command, including format on save. Uses glob pattern matching.",
          "scope": "resource"
        },
        "beautify.config": {
          "type": [
            "string",
            "object",
            "null"
          ],
          "default": null,
          "description": "A path to a file, or an object containing the configuration options for js-beautify. If the .jsbeautifyrc file exists in project root, it overrides this configuration.",
          "scope": "resource"
        },
        "beautify.language": {
          "type": "object",
          "description": "Link file types to the beautifier type",
          "scope": "resource",
          "default": {
            "js": {
              "type": [
                "javascript",
                "json",
                "jsonc"
              ],
              "filename": [
                ".jshintrc",
                ".jsbeautifyrc"
              ]
            },
            "css": [
              "css",
              "less",
              "scss"
            ],
            "html": [
              "htm",
              "html"
            ]
          },
          "properties": {
            "js": {
              "type": [
                "object",
                "array",
                "null"
              ],
              "items": {
                "type": "string"
              },
              "description": "Array of language types, or an object containing types, extensions and filenames to associate",
              "properties": {
                "type": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "VS Code language name"
                },
                "ext": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "File extensions (without the leading dot)"
                },
                "filename": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Full filenames (eg: '.jsbeautifyrc')"
                }
              }
            },
            "css": {
              "type": [
                "object",
                "array",
                "null"
              ],
              "items": {
                "type": "string"
              },
              "description": "Array of language types, or an object containing types, extensions and filenames to associate",
              "properties": {
                "type": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "VS Code language name"
                },
                "ext": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "File extensions (without the leading dot)"
                },
                "filename": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Full filenames (eg: '.jsbeautifyrc')"
                }
              }
            },
            "html": {
              "type": [
                "object",
                "array",
                "null"
              ],
              "items": {
                "type": "string"
              },
              "description": "Array of language types, or an object containing types, extensions and filenames to associate",
              "properties": {
                "type": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "VS Code language name"
                },
                "ext": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "File extensions (without the leading dot)"
                },
                "filename": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Full filenames (eg: '.jsbeautifyrc')"
                }
              }
            }
          }
        }
      }
    }
  },
  "dependencies": {
    "editorconfig": "^0.15.0",
    "js-beautify": "^1.15.0",
    "minimatch": "^3.0.4"
  },
  "devDependencies": {
    "@types/mocha": "^2.2.42",
    "@types/node": "^8.10.36",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.1",
    "expect.js": "^0.3.1",
    "mocha": "^5.2.0",
    "vscode": "~1.1.18"
  },
  "scripts": {
    "postinstall": "node ./node_modules/vscode/bin/install",
    "build": "esbuild extension.js --bundle --outfile=dist/extension.js --format=cjs --platform=node --external:vscode --minify",
    "test": "node ./node_modules/vscode/bin/test",
    "lint": "eslint extension.js options.js test/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Marvello/VSCodeBeautify"
  },
  "bugs": {
    "url": "https://github.com/Marvello/VSCodeBeautify/issues"
  }
}
